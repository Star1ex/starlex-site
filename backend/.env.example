# Starlex backend environment template.
# Copy to backend/.env for local development. Never commit real secrets.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=starlex_admin
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=starlex
DB_SSL_MODE=disable
DATABASE_URL=postgresql://starlex_admin:CHANGE_ME_strong_password@localhost:5432/starlex

# App
APP_ENV=development
BACKEND_PORT=3000
PORT=3000
FRONTEND_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
JWT_SECRET=CHANGE_ME_generate_32_plus_random_chars
SENTRY_DSN=

# Reverse proxy IP handling.
# Production behind localhost nginx can keep the default below. Add Docker subnet
# or proxy IPs when another trusted reverse proxy talks directly to Fiber.
TRUSTED_PROXIES=127.0.0.1,::1

# Storage
STORAGE_TYPE=local
LOCAL_PATH=./uploads
LOCAL_URL=/uploads/

# Cloudflare R2 / S3-compatible storage. Set STORAGE_TYPE=r2 to enable.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_KEY_PREFIX=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME_app_password
SMTP_FROM_EMAIL=CHANGE_ME@gmail.com
SMTP_FROM_NAME=Starlex

# Telegram notifications are optional.
TOKEN_TELEGRAM_NOTIFICATIONS=
CHAT_ID_TELEGRAM_BOT_NOTIFICATIONS=
