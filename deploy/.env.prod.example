# Starlex production env — copy to the server as:
#   /opt/starlex/prod/backend/.env
# This file stays ONLY on the server. Never commit real values to git.
# docker-compose.prod.yml overrides DB_HOST/DB_PORT/DB_SSL_MODE/PORT for Docker.

# ── Database (Postgres runs in the compose stack) ──────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=starlex_admin
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=starlex
DB_SSL_MODE=disable
# DATABASE_URL must match the values above (host stays `db` inside Docker)
DATABASE_URL=postgresql://starlex_admin:CHANGE_ME_strong_password@db:5432/starlex

# Port the Go app listens on inside the container (compose forces 3000 too)
BACKEND_PORT=3000
PORT=3000

# ── Storage (backend serves /uploads via app.Static) ───────────────────────
STORAGE_TYPE=local
LOCAL_PATH=./uploads
LOCAL_URL=/uploads/

# ── App / URLs ─────────────────────────────────────────────────────────────
APP_ENV=production
FRONTEND_BASE_URL=https://starlex.cc
ALLOWED_ORIGINS=https://starlex.cc
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── OAuth ──────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://starlex.cc/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://starlex.cc/api/auth/github/callback

# ── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME_app_password
SMTP_FROM_EMAIL=CHANGE_ME@gmail.com
SMTP_FROM_NAME=Starlex

# ── Telegram notifications (optional) ──────────────────────────────────────
TOKEN_TELEGRAM_NOTIFICATIONS=
CHAT_ID_TELEGRAM_BOT_NOTIFICATIONS=
